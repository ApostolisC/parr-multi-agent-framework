# =============================================================================
# Environment Variables for PARR Framework
# =============================================================================
# Copy this file to .env and fill in your values.
# The .env file is git-ignored and will not be committed.
#
# The framework reads these via ${VAR_NAME} references in providers.yaml.
# Set them in your shell or .env loader before running.
# =============================================================================

# --- Azure OpenAI ---
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# --- OpenAI ---
# OPENAI_API_KEY=sk-your-openai-api-key

# --- Anthropic ---
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
